{
    "version": 2,
    "framework": null,
    "functions": {
      "api/index.php": {
        "runtime": "vercel-php@0.6.0"
      }
    },
    "routes": [
      {
        "src": "/build/(.*)",
        "dest": "/public/build/$1"
      },
      {
        "src": "/img/(.*)",
        "dest": "/public/img/$1"
      },
      {
        "src": "/favicon.ico",
        "dest": "/public/favicon.ico"
      },
      {
        "src": "/robots.txt",
        "dest": "/public/robots.txt"
      },
      {
        "src": "/(.*)",
        "dest": "/api/index.php"
      }
    ],
    "public": true,
    "buildCommand": "npm run build",
    "outputDirectory": "public",
    "env": {
      "APP_NAME": "AI Sales Page Generator",
      "APP_ENV": "production",
      "APP_DEBUG": "false",
      "APP_URL": "https://ai-sales-page-generator-bay.vercel.app",
  
      "APP_CONFIG_CACHE": "/tmp/config.php",
      "APP_EVENTS_CACHE": "/tmp/events.php",
      "APP_PACKAGES_CACHE": "/tmp/packages.php",
      "APP_ROUTES_CACHE": "/tmp/routes.php",
      "APP_SERVICES_CACHE": "/tmp/services.php",
      "VIEW_COMPILED_PATH": "/tmp",
  
      "LOG_CHANNEL": "stderr",
      "LOG_LEVEL": "debug",
  
      "SESSION_DRIVER": "cookie",
      "SESSION_LIFETIME": "120",
      "SESSION_ENCRYPT": "false",
      "SESSION_PATH": "/",
  
      "CACHE_STORE": "array",
      "QUEUE_CONNECTION": "sync",
      "BROADCAST_CONNECTION": "log",
      "FILESYSTEM_DISK": "local",
  
      "MAIL_MAILER": "log",
      "MAIL_FROM_ADDRESS": "hello@example.com",
      "MAIL_FROM_NAME": "AI Sales Page Generator",
  
      "VITE_APP_NAME": "AI Sales Page Generator",
  
      "AI_PROVIDER": "hugging_face",
      "HUGGING_FACE_BASE_URL": "https://api-inference.huggingface.co/models",
      "HUGGING_FACE_MODEL": "gpt2"
    }
  }